            "url": {
              "raw": "{{base_url}}/schedules/check-constraints",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "schedules",
                "check-constraints"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"room_code\": \"2B11\",\n  \"lecturer_user_id\": 3,\n  \"practice_team_id\": 1,\n  \"day_of_week\": 6,\n  \"time_slot\": \"1-4\",\n  \"start_date\": \"2026-05-20\",\n  \"end_date\": \"2026-05-20\",\n  \"required_software_ids\": []\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 and passed', function () { var j = pm.response.json(); pm.response.to.have.status(200); pm.expect(j.data.passed).to.be.true; });"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 ROOM_CONFLICT",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{cbdt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/schedules/check-constraints",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "schedules",
                "check-constraints"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"room_code\": \"2B31\",\n  \"lecturer_user_id\": 3,\n  \"practice_team_id\": 1,\n  \"day_of_week\": 4,\n  \"time_slot\": \"7-10\",\n  \"start_date\": \"2025-09-17\",\n  \"end_date\": \"2025-09-17\",\n  \"required_software_ids\": []\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Fails with ROOM_CONFLICT', function () { var j = pm.response.json(); pm.expect(j.data.passed).to.be.false; var codes = j.data.results.map(r=>r.code); pm.expect(codes).to.include('ROOM_CONFLICT'); });"
                ]
              }
            }
          ]
        },
