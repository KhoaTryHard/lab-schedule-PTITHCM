              "raw": "{\n  \"practice_team_id\": 1,\n  \"start_date\": \"2026-05-20\",\n  \"end_date\": \"2026-05-20\",\n  \"lecturer_user_id\": 3\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is success with ranked options', function () { var j = pm.response.json(); pm.expect(j.data.auto_arrange_status).to.equal('success'); pm.expect(j.data.ranked_options).to.be.an('array'); pm.expect(j.data.ranked_options.length).to.be.at.least(1); });"
                ]
              }
