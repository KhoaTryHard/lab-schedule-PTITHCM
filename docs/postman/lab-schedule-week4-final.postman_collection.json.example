    {
      "name": "3. Check Constraint",
      "item": [
        {
          "name": "3.1 PASS case",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
