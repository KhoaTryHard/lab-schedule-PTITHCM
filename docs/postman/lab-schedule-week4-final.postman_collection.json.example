    {
      "name": "4. Auto-Arrange",
      "item": [
        {
          "name": "4.1 Success case",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
