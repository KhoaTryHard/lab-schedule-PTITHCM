          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is no_valid_option', function () { var j = pm.response.json(); pm.expect(j.data.auto_arrange_status).to.equal('no_valid_option'); });"
                ]
              }
            }
          ]
        },
