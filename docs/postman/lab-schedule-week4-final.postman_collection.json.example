              ],
              "path": [
                "schedule-requests"
              ],
              "query": []
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Returns array', function () { var j = pm.response.json(); pm.expect(j.data).to.be.an('array'); });"
                ]
              }
            }
          ]
        }
      ]
