              "raw": "{\n  \"room_code\": \"2B11\",\n  \"lecturer_user_id\": 3,\n  \"practice_team_id\": 999,\n  \"day_of_week\": 2,\n  \"time_slot\": \"1-4\",\n  \"start_date\": \"2026-05-20\",\n  \"end_date\": \"2026-05-20\",\n  \"required_software_ids\": []\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Fails with CAPACITY_OK overload', function () { var j = pm.response.json(); pm.expect(j.data.passed).to.be.false; var capacity = j.data.results.find(r=>r.code === 'CAPACITY_OK'); pm.expect(capacity).to.exist; pm.expect(capacity.passed).to.be.false; pm.expect(capacity.message).to.include('team size is 100'); });"
                ]
              }
            }
