            ],
            "url": {
              "raw": "{{base_url}}/schedule-requests",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "schedule-requests"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_section_id\": 1,\n  \"requested_team_count\": 1,\n  \"total_required_sessions\": 3\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Save request ID', function () { var j = pm.response.json(); pm.environment.set('schedule_request_id', j.data.id); });"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 GET Schedule Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
