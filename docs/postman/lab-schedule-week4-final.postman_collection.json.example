    {
      "name": "5. Schedule Lifecycle",
      "item": [
        {
          "name": "5.1 POST Draft",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{cbdt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/schedules",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "schedules"
              ],
              "query": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lab_schedule_request_id\": \"{{schedule_request_id}}\",\n  \"practice_team_id\": 1,\n  \"room_code\": \"2B11\",\n  \"lecturer_user_id\": 3,\n  \"day_of_week\": 6,\n  \"time_slot\": \"7-10\",\n  \"start_date\": \"2026-05-22\",\n  \"end_date\": \"2026-05-22\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Save schedule_id', function () { var j = pm.response.json(); pm.environment.set('schedule_id', j.data.schedule.id); });"
                ]
              }
            }
          ]
        },
        {
          "name": "5.2 PATCH Publish when draft",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{cbdt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/schedules/{{schedule_id}}/publish",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "schedules",
                "{{schedule_id}}",
                "publish"
              ],
              "query": []
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 409 Conflict', function () { pm.response.to.have.status(409); });"
                ]
              }
            }
          ]
        },
        {
          "name": "5.3 PATCH Approve",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
