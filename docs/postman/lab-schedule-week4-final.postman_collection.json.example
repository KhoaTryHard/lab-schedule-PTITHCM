    {
      "name": "2. Schedule Request",
      "item": [
        {
          "name": "2.1 POST Schedule Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
