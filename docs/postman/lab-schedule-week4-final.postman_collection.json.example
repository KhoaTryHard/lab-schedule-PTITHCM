                  "pm.test('Score is 80 and preferred day selected', function () { var j = pm.response.json(); pm.expect(j.data.selected_option.score).to.equal(80); pm.expect(j.data.selected_option.day_of_week).to.equal(3); });"
                ]
              }
            }
          ]
